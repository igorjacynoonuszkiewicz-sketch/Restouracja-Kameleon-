# OpenShorts — Konfiguracja API
# Skopiuj ten plik jako .env w katalogu tools/openshorts/
# cp marketing/openshorts-config.env.example tools/openshorts/.env

# WYMAGANE — Google Gemini (darmowe konto na aistudio.google.com)
GEMINI_API_KEY=twoj_klucz_tutaj

# OPCJONALNE — ElevenLabs (dubbing głosowy, tłumaczenie na inne języki)
ELEVENLABS_API_KEY=twoj_klucz_tutaj

# OPCJONALNE — Upload-Post API (automatyczne publikowanie na TikTok/IG/YT)
UPLOAD_POST_API_KEY=twoj_klucz_tutaj

# AWS S3 (backup wideo, opcjonalne)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AWS_S3_BUCKET=

# Limity przetwarzania
MAX_CONCURRENT_JOBS=3
